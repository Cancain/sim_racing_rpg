{
  "name": "sim-career",
  "version": "0.0.1",
  "description": "Desktop-app som simulerar en racingkarriär ovanpå iRacings offline AI",
  "main": "dist/main/index.js",
  "scripts": {
    "build": "tsc",
    "start": "bun run build && electron .",
    "predev": "tsc",
    "dev": "concurrently -k -n tsc,electron -c blue,green \"tsc -w --preserveWatchOutput\" \"electron .\""
  },
  "dependencies": {
    "chokidar": "^4"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "concurrently": "^9.2.1",
    "electron": "^33.0.0",
    "typescript": "^6.0.3"
  }
}
